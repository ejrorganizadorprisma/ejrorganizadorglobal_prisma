NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/ejr_db?schema=public

# JWT
# IMPORTANTE: gere uma chave forte aleatoria. Use por exemplo:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# A API NAO sobe sem JWT_SECRET definido (sem fallback de seguranca).
JWT_SECRET=change-me-to-a-random-64-byte-hex-string

# Frontend URL (para CORS)
FRONTEND_URL=http://localhost:5173

# Logs
LOG_LEVEL=info
LOG_DIR=./logs
