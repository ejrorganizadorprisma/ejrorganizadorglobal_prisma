{
  "expo": {
    "name": "EJR OrGlobal v1.4.1",
    "slug": "ejr-vendedor",
    "version": "1.4.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B5C9A"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B5C9A"
      },
      "package": "com.ejr.vendedor",
      "versionCode": 16
    },
    "plugins": [
      "expo-sqlite",
      "expo-secure-store",
      "expo-asset",
      "expo-font",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Permitir que EJR OrGlobal acesse sua localizacao para registrar coordenadas de vendas e cobrancas."
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "Permitir que EJR OrGlobal acesse a camera para tirar fotos de comprovantes."
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "ios": {
      "bundleIdentifier": "com.ejr.vendedor"
    }
  }
}
