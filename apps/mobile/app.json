{
  "expo": {
    "name": "EJR Vendedor",
    "slug": "ejr-vendedor",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B5C9A"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B5C9A"
      },
      "package": "com.ejr.vendedor",
      "versionCode": 1
    },
    "plugins": [
      "expo-sqlite",
      "expo-secure-store",
      "expo-asset",
      "expo-font"
    ],
    "ios": {
      "bundleIdentifier": "com.ejr.vendedor"
    }
  }
}
